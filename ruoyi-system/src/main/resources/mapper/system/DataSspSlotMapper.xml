<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.DataSspSlotMapper">

    <resultMap type="DataSspSlot" id="DataSspSlotResult">
        <result property="id"    column="id"    />
        <result property="mediaId"    column="media_id"    />
        <result property="appId"    column="app_id"    />
        <result property="sspSlotId"    column="ssp_slot_id"    />
        <result property="dspSlotId"    column="dsp_slot_id"    />
        <result property="dspSlotCode"    column="dsp_slot_code"    />
        <result property="showPv"    column="show_pv"    />
        <result property="showUv"    column="show_uv"    />
        <result property="clickPv"    column="click_pv"    />
        <result property="clickUv"    column="click_uv"    />
        <result property="reqPv"    column="req_pv"    />
        <result property="reqUv"    column="req_uv"    />
        <result property="discard"    column="discard"    />
        <result property="retPv"    column="ret_pv"    />
        <result property="retUv"    column="ret_uv"    />
        <result property="spend"    column="spend"    />
        <result property="income"    column="income"    />
        <result property="discountClickPv"    column="discount_click_pv"    />
        <result property="discountShowPv"    column="discount_show_pv"    />
        <result property="dplsuccPv"    column="dplsucc_pv"    />
        <result property="completePv"    column="complete_pv"    />
        <result property="installPv"    column="install_pv"    />
        <result property="activatePv"    column="activate_pv"    />
        <result property="date"    column="date"    />
        <result property="createdAt"    column="created_at"    />
        <result property="appName"    column="app_name"    />
        <result property="sspAliseName"    column="ssp_alise_name"    />

        <result property="dspSlotName"    column="dsp_slot_name"    />
        <result property="mediaName"    column="media_name"    />
        <result property="sspPayType"    column="ssp_pay_type"    />
        <result property="sspDealRatio"    column="ssp_deal_ratio"    />
        <result property="sspEcpm"    column="ssp_ecpm"    />
        <result property="appOsType" column="app_os_type"/>
        <result property="adType" column="ad_type"/>
    </resultMap>

    <sql id="selectDataSspSlotVo">
        SELECT
        t.ssp_slot_id,
        t.date,

        SUM(t.show_pv) AS show_pv,
        SUM(t.click_pv) AS click_pv,
        SUM(t.req_count) AS req_pv,
        SUM(t.discard) AS discard,
        SUM(t.ret_pv) AS ret_pv,
        SUM(t.spend) AS spend,
        SUM(t.income) AS income,
        SUM(t.discount_click_pv) AS discount_click_pv,
        SUM(t.discount_show_pv) AS discount_show_pv,

        MAX(app.name) AS app_name,
        MAX(ssp_slot.name_alise) AS ssp_alise_name,
        MAX(ssp_slot.ssp_pay_type) AS ssp_pay_type,
        MAX(ssp_slot.ssp_deal_ratio) AS ssp_deal_ratio,
        MAX(ssp_slot.ssp_ecpm) AS ssp_ecpm,
        MAX(ssp_slot.media_id) AS ssp_media_id,
        MAX(app.os_type) AS app_os_type,
        MAX(media.name) AS media_name,
        MAX(ssp_slot.ad_type_id) AS ad_type
        FROM
        ${tableName} t
        LEFT JOIN
        ssp_slot_info ssp_slot ON t.ssp_slot_id = ssp_slot.id
        LEFT JOIN
        ssp_media media ON ssp_slot.media_id = media.id
        LEFT JOIN
        ssp_app app ON ssp_slot.app_id = app.id
        GROUP BY
        t.ssp_slot_id, t.date
    </sql>


    <sql id="selectDataSspSlotVoTODSPDATA">
        select t.id,
               t.media_id,
               t.app_id,
               t.ssp_slot_id,
               t.dsp_slot_id,
               t.dsp_slot_code,
               t.show_pv,
               t.show_uv,
               t.click_pv,
               t.click_uv,
               t.req_pv,
               t.req_uv,
               t.discard,
               t.ret_pv,
               t.ret_uv,
               t.spend,
               t.income,
               t.discount_click_pv,
               t.discount_show_pv,
               t.dplsucc_pv,
               t.complete_pv,
               t.install_pv,
               t.activate_pv,
               t.date,
               t.created_at,
        app.name as app_name,
        ssp_slot.name_alise as ssp_alise_name,
        ssp_slot.ssp_pay_type,
        ssp_slot.ssp_deal_ratio,
        ssp_slot.ssp_ecpm,
        ssp_slot.media_id,
        app.os_type as app_os_type,
        media.name as media_name,
        ssp_slot.ad_type_id as ad_type
        from ${tableName} t
        left join ssp_slot_info ssp_slot on t.ssp_slot_id = ssp_slot.id
        left join ssp_media media on ssp_slot.media_id = media.id
        left join ssp_app app on ssp_slot.app_id = app.id

    </sql>

    <select id="selectDataSspSlotList" parameterType="DataSspSlot" resultMap="DataSspSlotResult">
        <include refid="selectDataSspSlotVo"/>
        <where>
            <if test="mediaId != null "> and t.media_id = #{mediaId}</if>
            <if test="appId != null "> and t.app_id = #{appId}</if>
            <if test="sspSlotId != null "> and t.ssp_slot_id = #{sspSlotId}</if>
            <if test="dspSlotCode != null  and dspSlotCode != ''"> and t.dsp_slot_code = #{dspSlotCode}</if>
            <if test="showPv != null "> and t.show_pv = #{showPv}</if>
            <if test="showUv != null "> and t.show_uv = #{showUv}</if>
            <if test="clickPv != null "> and t.click_pv = #{clickPv}</if>
            <if test="clickUv != null "> and t.click_uv = #{clickUv}</if>
            <if test="reqPv != null "> and t.req_pv = #{reqPv}</if>
            <if test="reqUv != null "> and t.req_uv = #{reqUv}</if>
            <if test="discard != null "> and t.discard = #{discard}</if>
            <if test="retPv != null "> and t.ret_pv = #{retPv}</if>
            <if test="retUv != null "> and t.ret_uv = #{retUv}</if>
            <if test="spend != null "> and t.spend = #{spend}</if>
            <if test="income != null "> and t.income = #{income}</if>
            <if test="discountClickPv != null "> and t.discount_click_pv = #{discountClickPv}</if>
            <if test="discountShowPv != null "> and t.discount_show_pv = #{discountShowPv}</if>
            <if test="dplsuccPv != null "> and t.dplsucc_pv = #{dplsuccPv}</if>
            <if test="completePv != null "> and t.complete_pv = #{completePv}</if>
            <if test="installPv != null "> and t.install_pv = #{installPv}</if>
            <if test="activatePv != null "> and t.activate_pv = #{activatePv}</if>
            <if test="date != null "> and t.date = #{date}</if>
            <if test="createdAt != null "> and t.created_at = #{createdAt}</if>
            <if test="appOsType !=null and appOsType != ''">and app.os_type =#{appOsType}</if>
            <if test="adType !=null and adType != ''">and ssp_slot.ad_type_id =#{adType}</if>
            <if test="sspSlotIds != null and sspSlotIds != ''">
                and FIND_IN_SET(CAST(t.ssp_slot_id AS CHAR), #{sspSlotIds})
            </if>
            <if test="sspAliseNames != null and sspAliseNames != ''">
                and FIND_IN_SET(ssp_slot.name_alise, #{sspAliseNames})
            </if>
        </where>
    </select>

    <select id="selectDataSspSlotListToDspData" parameterType="DataSspSlot" resultMap="DataSspSlotResult">
        <include refid="selectDataSspSlotVoTODSPDATA"/>
        <where>
            <if test="mediaId != null "> and t.media_id = #{mediaId}</if>
            <if test="appId != null "> and t.app_id = #{appId}</if>
            <if test="sspSlotId != null "> and t.ssp_slot_id = #{sspSlotId}</if>
            <if test="dspSlotCode != null  and dspSlotCode != ''"> and t.dsp_slot_code = #{dspSlotCode}</if>
            <if test="dspSlotId != null and dspSlotId != ''">and t.dsp_slot_id = #{dspSlotId}</if>
            <if test="date != null "> and t.date = #{date}</if>
            <if test="createdAt != null "> and t.created_at = #{createdAt}</if>
            <if test="appOsType !=null and appOsType != ''">and app.os_type =#{appOsType}</if>
            <if test="adType !=null and adType != ''">and ssp_slot.ad_type_id =#{adType}</if>
            <if test="sspSlotIds != null and sspSlotIds != ''">
                and FIND_IN_SET(CAST(t.ssp_slot_id AS CHAR), #{sspSlotIds})
            </if>
            <if test="sspAliseNames != null and sspAliseNames != ''">
                and FIND_IN_SET(ssp_slot.name_alise, #{sspAliseNames})
            </if>
        </where>
    </select>


    <select id="selectDataSspSlotById" parameterType="DataSspSlot" resultMap="DataSspSlotResult">
        <include refid="selectDataSspSlotVo"/>
        where t.id = #{id}
    </select>

    <select id="selectDataSspSlotListInputExce" parameterType="DataSspSlot" resultMap="DataSspSlotResult">
       select * from ${tableName}  where dsp_slot_code = #{dspSlotCode} and dsp_slot_id = #{dspSlotId} and date = #{date}
    </select>



    <!-- 根据 dsp_slot_id、dsp_slot_code 和 date 批量更新 spend -->
    <update id="updateSpendByDspSlotInfo">
        update ${tableName}
        set spend = #{spend}
        where dsp_slot_id = #{dspSlotId}
          and dsp_slot_code = #{dspSlotCode}
          and date = #{date}
    </update>

    <!-- 根据 dsp_slot_id、dsp_slot_code 和 date 批量更新 income -->
    <update id="updateIncomeByDspSlotInfo">
        update ${tableName}
        set income = #{income}
        where dsp_slot_id = #{dspSlotId}
          and dsp_slot_code = #{dspSlotCode}
          and date = #{date}
    </update>

    <!-- 根据 dsp_slot_id、dsp_slot_code 和 date 查询 ssp_slot_id -->
    <select id="selectSspSlotIdByDspInfo" resultType="java.lang.Long">
        select ssp_slot_id
        from ${tableName}
        where dsp_slot_id = #{dspSlotId}
          and dsp_slot_code = #{dspSlotCode}
          and date = #{date}
        limit 1
    </select>

    <!-- 根据 ssp_slot_id 查询分成系数 -->
    <select id="selectSspDealRatio" resultType="java.lang.Integer">
        select ssp_deal_ratio
        from ssp_slot_info
        where id = #{sspSlotId}
          and enable = 1
    </select>

    <!-- 修改媒体数据报表（修正用） -->
    <update id="updateDataSspSlot" parameterType="DataSspSlot">
        update ${tableName}
        <set>
            <if test="spend != null">spend = #{spend},</if>
            <if test="income != null">income = #{income},</if>
        </set>
        where id = #{id}
    </update>

    <!-- 查询当前月需要计算的分成模式数据（用于定时任务） -->
    <select id="selectCurrentMonthDataForCalculation" resultMap="DataSspSlotResult">
        SELECT t.id, t.ssp_slot_id, t.dsp_slot_id, t.show_pv,
               ssp_slot.ssp_pay_type, ssp_slot.ssp_deal_ratio, ssp_slot.ssp_ecpm
        FROM ${tableName} t
        INNER JOIN ssp_slot_info ssp_slot ON t.ssp_slot_id = ssp_slot.id
        WHERE ssp_slot.ssp_pay_type = 1
          AND ssp_slot.enable = 1
          AND t.show_pv > 0
          AND ssp_slot.ssp_ecpm > 0
          AND (t.spend IS NULL OR t.spend = 0 OR t.income IS NULL OR t.income = 0)
    </select>

    <!-- 批量更新分成模式的预算流水和收入（用于定时任务） -->
    <update id="batchUpdateSpendAndIncome" parameterType="map">
        UPDATE ${params.tableName}
        <trim prefix="SET" suffixOverrides=",">
            spend = CASE id
        <foreach collection="params.list" item="item" separator=" ">
            WHEN #{item.id} THEN #{item.spend}
        </foreach>
        ELSE spend END,
            income = CASE id
        <foreach collection="params.list" item="item" separator=" ">
            WHEN #{item.id} THEN #{item.income}
        </foreach>
        ELSE income END
        </trim>
        WHERE id IN
        <foreach collection="params.list" item="item" open="(" separator="," close=")">
            #{item.id}
        </foreach>
    </update>

    <!-- 定时任务专用：批量更新分成模式的预算流水和收入 -->
    <update id="batchUpdateForSchedule">
        UPDATE ${tableName}
        <trim prefix="SET" suffixOverrides=",">
            spend = CASE id
        <foreach collection="list" item="item" separator=" ">
            WHEN #{item.id} THEN #{item.spend}
        </foreach>
        ELSE spend END,
            income = CASE id
        <foreach collection="list" item="item" separator=" ">
            WHEN #{item.id} THEN #{item.income}
        </foreach>
        ELSE income END
        </trim>
        WHERE id IN
        <foreach collection="list" item="item" open="(" separator="," close=")">
            #{item.id}
        </foreach>
    </update>
</mapper>
