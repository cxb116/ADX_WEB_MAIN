            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateDspSlotInfo" parameterType="DspSlotInfo">
        update dsp_slot_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="osType != null">os_type = #{osType},</if>
            <if test="adTypeId != null">ad_type_id = #{adTypeId},</if>
            <if test="adSceneId != null">ad_scene_id = #{adSceneId},</if>
            <if test="adSizeId != null">ad_size_id = #{adSizeId},</if>
            <if test="dspSlotCode != null and dspSlotCode != ''">dsp_slot_code = #{dspSlotCode},</if>
            <if test="dspAppKey != null">dsp_app_key = #{dspAppKey},</if>
            <if test="dspAppSecret != null">dsp_app_secret = #{dspAppSecret},</if>
            <if test="dspAppId != null">dsp_app_id = #{dspAppId},</if>
            <if test="dspAppPkg != null">dsp_app_pkg = #{dspAppPkg},</if>
