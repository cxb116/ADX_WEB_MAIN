            <if test="name != null and name != ''">name,</if>
            <if test="osType != null">os_type,</if>
            <if test="adTypeId != null">ad_type_id,</if>
            <if test="adSceneId != null">ad_scene_id,</if>
            <if test="adSizeId != null">ad_size_id,</if>
            <if test="dspSlotCode != null and dspSlotCode != ''">dsp_slot_code,</if>
            <if test="dspAppKey != null">dsp_app_key,</if>
            <if test="dspAppSecret != null">dsp_app_secret,</if>
            <if test="dspAppId != null">dsp_app_id,</if>
            <if test="dspAppPkg != null">dsp_app_pkg,</if>
            <if test="dspAppVer != null">dsp_app_ver,</if>
            <if test="dspAppStoreVer != null">dsp_app_store_ver,</if>
            <if test="priceEncryptKey != null">price_encrypt_key,</if>
            <if test="dspAppStoreLink != null">dsp_app_store_link,</if>
            <if test="dspPayType != null">dsp_pay_type,</if>
            <if test="dspDealRatio != null">dsp_deal_ratio,</if>
            <if test="companyId != null">company_id,</if>
            <if test="productId != null">product_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="osType != null">#{osType},</if>
            <if test="adTypeId != null">#{adTypeId},</if>
            <if test="adSceneId != null">#{adSceneId},</if>
            <if test="adSizeId != null">#{adSizeId},</if>
            <if test="dspSlotCode != null and dspSlotCode != ''">#{dspSlotCode},</if>
            <if test="dspAppKey != null">#{dspAppKey},</if>
            <if test="dspAppSecret != null">#{dspAppSecret},</if>
            <if test="dspAppId != null">#{dspAppId},</if>
            <if test="dspAppPkg != null">#{dspAppPkg},</if>
            <if test="dspAppVer != null">#{dspAppVer},</if>
            <if test="dspAppStoreVer != null">#{dspAppStoreVer},</if>
            <if test="priceEncryptKey != null">#{priceEncryptKey},</if>
            <if test="dspAppStoreLink != null">#{dspAppStoreLink},</if>
            <if test="dspPayType != null">#{dspPayType},</if>
            <if test="dspDealRatio != null">#{dspDealRatio},</if>
            <if test="companyId != null">#{companyId},</if>
            <if test="productId != null">#{productId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
