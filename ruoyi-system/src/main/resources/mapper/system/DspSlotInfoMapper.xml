<mapper namespace="com.ruoyi.system.mapper.DspSlotInfoMapper">
    
    <resultMap type="DspSlotInfo" id="DspSlotInfoResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="osType"    column="os_type"    />
        <result property="adTypeId"    column="ad_type_id"    />
        <result property="adSceneId"    column="ad_scene_id"    />
